# 🌍 VARIÁVEIS DE AMBIENTE - PET SOCIAL
# Configure estas variáveis para desenvolvimento e produção

# ==========================================
# 🔐 SUPABASE CONFIGURAÇÃO
# ==========================================
# URL do seu projeto Supabase
VITE_SUPABASE_URL=https://ftlgfaraeflseuafznnh.supabase.co

# Chave anônima do Supabase (pública)
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImZ0bGdmYXJhZWZsc2V1YWZ6bm5oIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzAxNzEzNjMsImV4cCI6MjA4NTc0NzM2M30.fVjkybYuOMHDUUHI2_913tJDyMJ4tPUVMuFXJoQuMvs

# Chave de serviço (apenas backend, NUNCA expor no frontend)
# SUPABASE_SERVICE_ROLE_KEY=service-key-here

# ==========================================
# 🚀 CONFIGURAÇÃO DA APLICAÇÃO
# ==========================================
# Ambiente da aplicação
NODE_ENV=development

# URL da aplicação (para callbacks e redirecionamentos)
NEXT_PUBLIC_APP_URL=http://localhost:3000
VERCEL_URL=your-app.vercel.app

# Configurações de autenticação
NEXT_PUBLIC_ENABLE_EMAIL_CONFIRMATION=true
NEXT_PUBLIC_ENABLE_PHONE_VERIFICATION=false
NEXT_PUBLIC_ENABLE_SOCIAL_AUTH=true

# ==========================================
# 📧 CONFIGURAÇÃO DE EMAIL
# ==========================================
# Configurações do Resend (para emails transacionais)
RESEND_API_KEY=re_api_key_here
RESEND_FROM_EMAIL=noreply@petsocial.com
RESEND_FROM_NAME=PetSocial

# Configurações do SendGrid (alternativa)
# SENDGRID_API_KEY=SG.api_key_here
# SENDGRID_FROM_EMAIL=noreply@petsocial.com

# ==========================================
# 🗄️ CONFIGURAÇÃO DE BANCO DE DADOS
# ==========================================
# URL de conexão direta (se necessário)
# DATABASE_URL=postgresql://user:password@host:port/database

# ==========================================
# 📁 CONFIGURAÇÃO DE STORAGE
# ==========================================
# Configurações do AWS S3 (para uploads alternativos)
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=petsocial-uploads

# ==========================================
# 🔍 CONFIGURAÇÃO DE ANALYTICS
# ==========================================
# Google Analytics
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Vercel Analytics
NEXT_PUBLIC_VERCEL_ANALYTICS=true

# ==========================================
# 🐛 CONFIGURAÇÃO DE DEBUG
# ==========================================
# Ativar logs detalhados
DEBUG=supabase:*
NEXT_PUBLIC_DEBUG=false

# Nível de log
LOG_LEVEL=info

# ==========================================
# 🛡️ CONFIGURAÇÃO DE SEGURANÇA
# ==========================================
# Segredos para JWT (gerados automaticamente pelo Supabase)
# JWT_SECRET=your-jwt-secret
# JWT_EXPIRES_IN=7d

# Configuração de CORS
CORS_ORIGIN=http://localhost:3000,https://your-app.vercel.app

# ==========================================
# 🧪 CONFIGURAÇÃO DE TESTES
# ==========================================
# URL do Supabase de teste
TEST_SUPABASE_URL=https://test-project.supabase.co
TEST_SUPABASE_ANON_KEY=test-anon-key-here

# ==========================================
# 📱 CONFIGURAÇÃO DE FEATURES
# ==========================================
# Flags de funcionalidades
NEXT_PUBLIC_FEATURE_ADOPTION=true
NEXT_PUBLIC_FEATURE_CHAT=true
NEXT_PUBLIC_FEATURE_MARKETPLACE=false
NEXT_PUBLIC_FEATURE_EVENTS=false

# Limites e configurações
NEXT_PUBLIC_MAX_FILE_SIZE=5242880  # 5MB em bytes
NEXT_PUBLIC_MAX_BIO_LENGTH=500
NEXT_PUBLIC_MIN_USERNAME_LENGTH=3
NEXT_PUBLIC_MAX_USERNAME_LENGTH=30

# ==========================================
# 🚀 CONFIGURAÇÃO DE DEPLOY
# ==========================================
# Configurações específicas da Vercel
VERCEL_ENV=development
VERCEL_GIT_COMMIT_SHA=commit-sha-here
VERCEL_GIT_COMMIT_MESSAGE="Initial commit"

# Configurações de build
BUILD_ID=build-id-here

# ==========================================
# 📊 CONFIGURAÇÃO DE MONITORAMENTO
# ==========================================
# Sentry (error tracking)
NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_AUTH_TOKEN=your-sentry-auth-token

# LogRocket (session replay)
NEXT_PUBLIC_LOGROCKET_APP_ID=your-logrocket-app-id

# ==========================================
# 🔧 CONFIGURAÇÃO DE DESENVOLVIMENTO
# ==========================================
# Porta do servidor de desenvolvimento
PORT=3000

# Configuração do Hot Module Replacement
FAST_REFRESH=true

# ==========================================
# 📝 INSTRUÇÕES DE USO
# ==========================================

# 1️⃣ CÓPIE ESTE ARQUIVO:
# cp .env.example .env.local

# 2️⃣ CONFIGURE AS VARIÁVEIS:
# - Substitua as URLs e chaves do Supabase
# - Configure as chaves de email se necessário
# - Ajuste as URLs para seu ambiente

# 3️⃣ VARIÁVEIS PÚBLICAS (NEXT_PUBLIC_):
# - São expostas no frontend
# - Use apenas dados não sensíveis

# 4️⃣ VARIÁVEIS PRIVADAS:
# - Acessíveis apenas no backend
# - Use para chaves secretas e dados sensíveis

# 5️⃣ NUNCA COMMIT .env.local:
# # Adicione ao .gitignore
# echo ".env.local" >> .gitignore

# 6️⃣ PARA PRODUÇÃO:
# - Configure as variáveis no painel da Vercel
# - Use secrets para dados sensíveis
# - Teste todas as funcionalidades

# 🚨 IMPORTANTE:
# - Mantenha suas chaves seguras
# - Use diferentes chaves para dev/prod
# - Roteie as variáveis regularmente
# - Monitore acesso não autorizado
